# Copy to .env and source it before running `python backend/run.py`
# (or use python-dotenv).

# --- LLM ----------------------------------------------------------------
# Leave ANTHROPIC_API_KEY empty to run with the offline heuristic mock.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
QUANTFLOW_LLM_MODE=auto

# --- Storage ------------------------------------------------------------
# Default = SQLite at quantflow/quantflow.db.
# For production, swap to Postgres + TimescaleDB:
# QUANTFLOW_DATABASE_URL=postgresql://user:pass@host:5432/quantflow
QUANTFLOW_DATABASE_URL=

# --- Backtest defaults --------------------------------------------------
QUANTFLOW_INITIAL_CAPITAL=100000
QUANTFLOW_POSITION_SIZE=1.0
QUANTFLOW_DATA_LIMIT=20000

# --- Server -------------------------------------------------------------
QUANTFLOW_HOST=127.0.0.1
QUANTFLOW_PORT=8000
QUANTFLOW_RELOAD=true
QUANTFLOW_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
